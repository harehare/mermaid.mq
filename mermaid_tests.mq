# ─── mermaid_to_string: unknown type ─────────────────────────────────────────

def test_to_string_unknown_header():
  let result = mermaid_to_string(mermaid_parse("gantt\n  title Plan\n  task1 : 2024-01-01, 7d"))
  | assert_eq(first(split(result, "\n")), "gantt")
end

def test_to_string_unknown_raw_lines():
  let result = mermaid_to_string(mermaid_parse("gantt\n  title Plan\n  task1 : 2024-01-01, 7d"))
  | assert_contains(split(result, "\n"), "  title Plan")
end

# ─── round-trip: mermaid_parse(mermaid_to_string(mermaid_parse(x))) ───────────

def test_roundtrip_flowchart_type():
  let parsed = mermaid_parse(_flowchart_lr())
  | let rt    = mermaid_parse(mermaid_to_string(parsed))
  | assert_eq(rt["type"], parsed["type"])
end

def test_roundtrip_flowchart_direction():
  let parsed = mermaid_parse(_flowchart_lr())
  | let rt    = mermaid_parse(mermaid_to_string(parsed))
  | assert_eq(rt["direction"], parsed["direction"])
end

def test_roundtrip_flowchart_node_count():
  let parsed = mermaid_parse(_flowchart_lr())
  | let rt    = mermaid_parse(mermaid_to_string(parsed))
  | assert_len(rt["nodes"], len(parsed["nodes"]))
end

def test_roundtrip_flowchart_node_ids():
  let parsed = mermaid_parse(_flowchart_lr())
  | let rt    = mermaid_parse(mermaid_to_string(parsed))
  | let rt_ids = map(rt["nodes"], fn(n): n["id"];)
  | assert_contains(rt_ids, "A")
  | assert_contains(rt_ids, "B")
  | assert_contains(rt_ids, "C")
  | assert_contains(rt_ids, "D")
end

def test_roundtrip_flowchart_node_shapes():
  let parsed = mermaid_parse(_flowchart_lr())
  | let rt    = mermaid_parse(mermaid_to_string(parsed))
  | let nd_b  = first(filter(rt["nodes"], fn(n): n["id"] == "B";))
  | assert_eq(nd_b["shape"], "diamond")
end

def test_roundtrip_flowchart_edge_count():
  let parsed = mermaid_parse(_flowchart_lr())
  | let rt    = mermaid_parse(mermaid_to_string(parsed))
  | assert_len(rt["edges"], len(parsed["edges"]))
end

def test_roundtrip_flowchart_edge_label():
  let parsed = mermaid_parse(_flowchart_lr())
  | let rt    = mermaid_parse(mermaid_to_string(parsed))
  | let yes_e = first(filter(rt["edges"], fn(e): e["label"] == "yes";))
  | assert_eq(yes_e["from"], "B")
  | assert_eq(yes_e["to"],   "C")
end

def test_roundtrip_flowchart_td_direction():
  let parsed = mermaid_parse(_flowchart_td())
  | let rt    = mermaid_parse(mermaid_to_string(parsed))
  | assert_eq(rt["direction"], "TD")
end

def test_roundtrip_seq_type():
  let parsed = mermaid_parse(_seq())
  | let rt    = mermaid_parse(mermaid_to_string(parsed))
  | assert_eq(rt["type"], parsed["type"])
end

def test_roundtrip_seq_participant_count():
  let parsed = mermaid_parse(_seq())
  | let rt    = mermaid_parse(mermaid_to_string(parsed))
  | assert_len(rt["participants"], len(parsed["participants"]))
end

def test_roundtrip_seq_participant_names():
  let parsed = mermaid_parse(_seq())
  | let rt    = mermaid_parse(mermaid_to_string(parsed))
  | let nms   = map(rt["participants"], fn(p): p["name"];)
  | assert_contains(nms, "Alice")
  | assert_contains(nms, "Bob")
end

def test_roundtrip_seq_message_count():
  let parsed = mermaid_parse(_seq())
  | let rt    = mermaid_parse(mermaid_to_string(parsed))
  | assert_len(rt["messages"], len(parsed["messages"]))
end

def test_roundtrip_seq_message_arrow():
  let parsed = mermaid_parse(_seq())
  | let rt    = mermaid_parse(mermaid_to_string(parsed))
  | let msg   = first(rt["messages"])
  | assert_eq(msg["arrow"], "->>")
end

def test_roundtrip_seq_alias():
  let parsed = mermaid_parse(_seq_alias())
  | let rt    = mermaid_parse(mermaid_to_string(parsed))
  | let p_a   = first(filter(rt["participants"], fn(p): p["name"] == "A";))
  | assert_eq(p_a["alias"], "Alice")
end

def test_roundtrip_pie_type():
  let parsed = mermaid_parse(_pie())
  | let rt    = mermaid_parse(mermaid_to_string(parsed))
  | assert_eq(rt["type"], parsed["type"])
end

def test_roundtrip_pie_title():
  let parsed = mermaid_parse(_pie())
  | let rt    = mermaid_parse(mermaid_to_string(parsed))
  | assert_eq(rt["title"], parsed["title"])
end

def test_roundtrip_pie_slice_count():
  let parsed = mermaid_parse(_pie())
  | let rt    = mermaid_parse(mermaid_to_string(parsed))
  | assert_len(rt["slices"], len(parsed["slices"]))
end

def test_roundtrip_pie_slice_labels():
  let parsed = mermaid_parse(_pie())
  | let rt    = mermaid_parse(mermaid_to_string(parsed))
  | let lbls  = map(rt["slices"], fn(s): s["label"];)
  | assert_contains(lbls, "Rust")
  | assert_contains(lbls, "Go")
  | assert_contains(lbls, "Python")
end

def test_roundtrip_pie_no_title():
  let parsed = mermaid_parse(_pie_no_title())
  | let rt    = mermaid_parse(mermaid_to_string(parsed))
  | assert_eq(rt["title"], "")
end

def test_roundtrip_class_type():
  let parsed = mermaid_parse(_class())
  | let rt    = mermaid_parse(mermaid_to_string(parsed))
