include "test"
| include "mermaid"
|

def _flowchart_lr():
  "graph LR\n  A[Start] --> B{Decision}\n  B -->|yes| C[Done]\n  B -->|no| D[Skip]"
end

def _flowchart_td():
  "flowchart TD\n  A --> B\n  B --> C"
end

def _seq():
  "sequenceDiagram\n  participant Alice\n  participant Bob\n  Alice ->> Bob: Hello\n  Bob -->> Alice: World"
end

def _pie():
  "pie title Languages\n  \"Rust\" : 45\n  \"Go\" : 30\n  \"Python\" : 25"
end

def _class():
  "classDiagram\n  class Animal\n  class Dog\n  Animal <|-- Dog : inherits"
end

# -- flowchart type --

def test_flowchart_type():
  let result = mermaid_parse(_flowchart_lr())
  | assert_eq(result["type"], "flowchart")
end

def test_graph_type_also_flowchart():
  let result = mermaid_parse(_flowchart_td())
  | assert_eq(result["type"], "flowchart")
end

def test_flowchart_direction_lr():
  let result = mermaid_parse(_flowchart_lr())
  | assert_eq(result["direction"], "LR")
end

def test_flowchart_direction_td():
  let result = mermaid_parse(_flowchart_td())
  | assert_eq(result["direction"], "TD")
end

# -- flowchart nodes --

def test_flowchart_nodes_exist():
  let result = mermaid_parse(_flowchart_lr())
  | assert_not_empty(result["nodes"])
end

def test_flowchart_node_rect_shape():
  let result = mermaid_parse(_flowchart_lr())
  | let node = first(filter(result["nodes"], fn(n): n["id"] == "A";))
  | assert_eq(node["shape"], "rect")
end

def test_flowchart_node_diamond_shape():
  let result = mermaid_parse(_flowchart_lr())
  | let node = first(filter(result["nodes"], fn(n): n["id"] == "B";))
  | assert_eq(node["shape"], "diamond")
end

def test_flowchart_node_label():
  let result = mermaid_parse(_flowchart_lr())
  | let node = first(filter(result["nodes"], fn(n): n["id"] == "A";))
  | assert_eq(node["label"], "Start")
end

def test_flowchart_simple_nodes_collected():
  let result = mermaid_parse(_flowchart_td())
  | let ids = map(result["nodes"], fn(n): n["id"];)
  | assert_contains(ids, "A")
  | assert_contains(ids, "B")
  | assert_contains(ids, "C")
end

# -- flowchart edges --

def test_flowchart_edge_count():
  let result = mermaid_parse(_flowchart_lr())
  | assert_len(result["edges"], 3)
end

def test_flowchart_edge_from_to():
  let result = mermaid_parse(_flowchart_lr())
  | let edge = first(filter(result["edges"], fn(e): e["from"] == "A";))
  | assert_eq(edge["to"], "B")
end

def test_flowchart_edge_with_label():
  let result = mermaid_parse(_flowchart_lr())
  | let labeled = filter(result["edges"], fn(e): len(e["label"]) > 0;)
  | assert_not_empty(labeled)
  | let yes_edge = first(filter(labeled, fn(e): e["label"] == "yes";))
  | assert_eq(yes_edge["from"], "B")
  | assert_eq(yes_edge["to"], "C")
end

def test_flowchart_simple_edge_count():
  let result = mermaid_parse(_flowchart_td())
  | assert_len(result["edges"], 2)
end

# -- sequence diagram --

def test_seq_type():
  let result = mermaid_parse(_seq())
  | assert_eq(result["type"], "sequenceDiagram")
end

def test_seq_participant_count():
  let result = mermaid_parse(_seq())
  | assert_len(result["participants"], 2)
end

def test_seq_participant_names():
  let result = mermaid_parse(_seq())
  | let names = map(result["participants"], fn(p): p["name"];)
  | assert_contains(names, "Alice")
  | assert_contains(names, "Bob")
end

def test_seq_message_count():
  let result = mermaid_parse(_seq())
  | assert_len(result["messages"], 2)
end

def test_seq_message_from_to():
  let result = mermaid_parse(_seq())
  | let msg = first(result["messages"])
  | assert_eq(msg["from"], "Alice")
  | assert_eq(msg["to"], "Bob")
end

def test_seq_message_text():
  let result = mermaid_parse(_seq())
  | let msg = first(result["messages"])
  | assert_eq(msg["text"], "Hello")
end

# -- pie chart --

def test_pie_type():
  let result = mermaid_parse(_pie())
  | assert_eq(result["type"], "pie")
end

def test_pie_title():
  let result = mermaid_parse(_pie())
  | assert_eq(result["title"], "Languages")
end

def test_pie_slice_count():
  let result = mermaid_parse(_pie())
  | assert_len(result["slices"], 3)
end

def test_pie_slice_label():
  let result = mermaid_parse(_pie())
  | let slice = first(result["slices"])
  | assert_eq(slice["label"], "Rust")
end

def test_pie_slice_value():
  let result = mermaid_parse(_pie())
  | let slice = first(result["slices"])
  | assert_eq(slice["value"], 45)
end

# -- class diagram --

def test_class_type():
  let result = mermaid_parse(_class())
  | assert_eq(result["type"], "classDiagram")
end

def test_class_names():
  let result = mermaid_parse(_class())
  | let names = map(result["classes"], fn(c): c["name"];)
  | assert_contains(names, "Animal")
  | assert_contains(names, "Dog")
end

def test_class_relation_count():
  let result = mermaid_parse(_class())
  | assert_len(result["relations"], 1)
end

def test_class_relation_from_to():
  let result = mermaid_parse(_class())
  | let rel = first(result["relations"])
  | assert_eq(rel["from"], "Animal")
  | assert_eq(rel["to"], "Dog")
end

# -- unknown type --

def test_unknown_type():
  let result = mermaid_parse("gantt\n  title Plan\n  task1 : 2024-01-01, 7d")
  | assert_eq(result["type"], "gantt")
end

# ─── additional fixtures ───────────────────────────────────────────────────────

def _flowchart_shapes():
  "graph TB\n  A((Circle))\n  B([Stadium])\n  C(Round)\n  D{Diamond}\n  E[Rect]"
end

def _flowchart_standalone():
  "graph LR\n  A[Alone]"
end

def _seq_alias():
  "sequenceDiagram\n  participant A as Alice\n  participant B as Bob\n  A ->> B: Hello\n  B -->> A: World"
end

def _pie_no_title():
  "pie\n  \"X\" : 60\n  \"Y\" : 40"
end

def _class_no_label():
  "classDiagram\n  class Foo\n  class Bar\n  Foo -- Bar"
end

# ─── mermaid_to_string: flowchart ─────────────────────────────────────────────

def test_to_string_flowchart_not_empty():
  let result = mermaid_to_string(mermaid_parse(_flowchart_lr()))
  | assert_not_empty(result)
end

def test_to_string_flowchart_lr_header():
  let result = mermaid_to_string(mermaid_parse(_flowchart_lr()))
  | assert_eq(first(split(result, "\n")), "graph LR")
end

def test_to_string_flowchart_td_header():
  let result = mermaid_to_string(mermaid_parse(_flowchart_td()))
  | assert_eq(first(split(result, "\n")), "graph TD")
end

def test_to_string_flowchart_edge_no_label():
  let result = mermaid_to_string(mermaid_parse(_flowchart_td()))
  | assert_contains(split(result, "\n"), "  A --> B")
end

def test_to_string_flowchart_edge_with_label_yes():
  let result = mermaid_to_string(mermaid_parse(_flowchart_lr()))
  | assert_contains(split(result, "\n"), "  B{Decision} -->|yes| C[Done]")
end

def test_to_string_flowchart_edge_with_label_no():
  let result = mermaid_to_string(mermaid_parse(_flowchart_lr()))
  | assert_contains(split(result, "\n"), "  B{Decision} -->|no| D[Skip]")
end

def test_to_string_flowchart_rect_node_in_edge():
  let result = mermaid_to_string(mermaid_parse(_flowchart_lr()))
  | assert_contains(split(result, "\n"), "  A[Start] --> B{Decision}")
end

def test_to_string_flowchart_standalone_node():
  let result = mermaid_to_string(mermaid_parse(_flowchart_standalone()))
  | assert_contains(split(result, "\n"), "  A[Alone]")
end

def test_to_string_flowchart_standalone_line_count():
  let result = mermaid_to_string(mermaid_parse(_flowchart_standalone()))
  | assert_len(split(result, "\n"), 2)
end

# ─── mermaid_to_string: node shapes ──────────────────────────────────────────

def test_to_string_node_circle():
  let result = mermaid_to_string(mermaid_parse(_flowchart_shapes()))
  | assert_contains(split(result, "\n"), "  A((Circle))")
end

def test_to_string_node_stadium():
  let result = mermaid_to_string(mermaid_parse(_flowchart_shapes()))
  | assert_contains(split(result, "\n"), "  B([Stadium])")
end

def test_to_string_node_round():
  let result = mermaid_to_string(mermaid_parse(_flowchart_shapes()))
  | assert_contains(split(result, "\n"), "  C(Round)")
end

def test_to_string_node_diamond():
  let result = mermaid_to_string(mermaid_parse(_flowchart_shapes()))
  | assert_contains(split(result, "\n"), "  D{Diamond}")
end

def test_to_string_node_rect():
  let result = mermaid_to_string(mermaid_parse(_flowchart_shapes()))
  | assert_contains(split(result, "\n"), "  E[Rect]")
end

def test_to_string_node_simple_id_no_brackets():
  let result = mermaid_to_string(mermaid_parse(_flowchart_td()))
  | assert_contains(split(result, "\n"), "  A --> B")
end

# ─── mermaid_to_string: sequence diagram ─────────────────────────────────────

def test_to_string_seq_header():
  let result = mermaid_to_string(mermaid_parse(_seq()))
  | assert_eq(first(split(result, "\n")), "sequenceDiagram")
end

def test_to_string_seq_participant_alice():
  let result = mermaid_to_string(mermaid_parse(_seq()))
  | assert_contains(split(result, "\n"), "  participant Alice")
end

def test_to_string_seq_participant_bob():
  let result = mermaid_to_string(mermaid_parse(_seq()))
  | assert_contains(split(result, "\n"), "  participant Bob")
end

def test_to_string_seq_message_forward():
  let result = mermaid_to_string(mermaid_parse(_seq()))
  | assert_contains(split(result, "\n"), "  Alice ->> Bob: Hello")
end

def test_to_string_seq_message_return():
  let result = mermaid_to_string(mermaid_parse(_seq()))
  | assert_contains(split(result, "\n"), "  Bob -->> Alice: World")
end

def test_to_string_seq_alias_name():
  let result = mermaid_to_string(mermaid_parse(_seq_alias()))
  | assert_contains(split(result, "\n"), "  participant A as Alice")
end

def test_to_string_seq_alias_b():
  let result = mermaid_to_string(mermaid_parse(_seq_alias()))
  | assert_contains(split(result, "\n"), "  participant B as Bob")
end

